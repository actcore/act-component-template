[package]
name = "component-{{ project_name }}"
description = "{{ project_description }}"
version = "0.1.0"
edition = "2024"

[dependencies]
act-sdk = "0.2"
wit-bindgen = { version = "0.54", features = ["async-spawn"] }

[profile.release]
lto = "fat"
codegen-units = 1
strip = true
opt-level = "z"

[lib]
crate-type = ["cdylib"]
